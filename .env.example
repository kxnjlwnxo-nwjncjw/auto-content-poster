# Claude AI (get at console.anthropic.com)
ANTHROPIC_API_KEY=your_key_here

# Twitter / X (get at developer.x.com)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# Instagram (your account credentials)
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# Facebook (get at developers.facebook.com)
FACEBOOK_PAGE_ID=
FACEBOOK_ACCESS_TOKEN=

# Telegram (create a bot via @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# TikTok (session ID from browser cookies)
TIKTOK_SESSION_ID=

# Composio (get at app.composio.dev — used for YouTube posting)
COMPOSIO_API_KEY=your_composio_api_key_here

# Higgsfield AI (get at higgsfield.ai/dashboard — generates intro videos, thumbnails, b-roll)
HIGGSFIELD_API_KEY=your_higgsfield_api_key_here
HIGGSFIELD_SCENES_COUNT=3

# YouTube OAuth (alternative to Composio — run `python main.py youtube auth` to authenticate)
YOUTUBE_CLIENT_SECRET_FILE=config/youtube_client_secret.json
YOUTUBE_TOKEN_FILE=data/youtube_token.pickle

# Review dashboard settings (optional)
YOUTUBE_DASHBOARD_HOST=127.0.0.1
YOUTUBE_DASHBOARD_PORT=8080

# ── Multi-agent system ────────────────────────────────────────────────────────

# How often to generate a new YouTube draft (minutes, default: 60)
CONTENT_AGENT_INTERVAL_MINUTES=60

# Which niches to use (comma-separated, blank = all). E.g. "fitness,tech"
CONTENT_AGENT_NICHES=

# Privacy for auto-generated videos
YOUTUBE_DEFAULT_PRIVACY=public

# Auto-approve content once assets are ready (true = fully autonomous pipeline)
YOUTUBE_AUTO_APPROVE=false

# Or: approve after N minutes of waiting (0 = disabled, requires YOUTUBE_AUTO_APPROVE=true OR set alone)
YOUTUBE_REVIEW_WINDOW_MINUTES=0

# Git agent: commit interval (minutes) and push behavior
GIT_AGENT_INTERVAL_MINUTES=10
GIT_AUTO_PUSH=true
GIT_BRANCH=main
